{
  "name": "cogvest",
  "version": "1.0.0",
  "main": "./index.ts",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "android": "expo run:android",
    "doctor": "expo-doctor",
    "test": "jest --runInBand",
    "typecheck": "tsc --noEmit",
    "android:doctor": "node scripts/android-doctor.mjs",
    "android:smoke": "node scripts/android-smoke-check.mjs",
    "test:verify": "npm run typecheck && npm test && npm run doctor",
    "test:v1:pc": "npm run test:verify && npm run android:doctor && npm run android:smoke -- --strict",
    "maestro:check": "node scripts/maestro-check.mjs",
    "maestro:test": "node scripts/maestro-run.mjs",
    "visual-qa:android": "node scripts/android-visual-qa.mjs",
    "preview:v1:research": "node scripts/preview-server.mjs serve",
    "preview:v1:research:start": "node scripts/preview-server.mjs start",
    "preview:v1:research:status": "node scripts/preview-server.mjs status",
    "preview:v1:research:stop": "node scripts/preview-server.mjs stop"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.ts"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/__tests__/**/*.test.tsx"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@hookform/resolvers": "^5.2.2",
    "@shopify/react-native-skia": "2.2.12",
    "expo": "~54.0.35",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.24",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.73.1",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-gifted-charts": "^1.4.77",
    "react-native-mmkv": "^4.3.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "expo-doctor": "^1.18.19",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.16",
    "react-test-renderer": "19.1.0",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "@tootallnate/once": "^3.0.1",
    "postcss": "^8.5.10"
  },
  "private": true
}
